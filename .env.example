# ── Copier ce fichier en .env et compléter les valeurs ──

# Application
NODE_ENV=development

# Base de données
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_IN_PROD
DB_NAME=myapp_dev
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# Sécurité — générer avec : openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS

# CORS — séparer plusieurs origines par des virgules
CORS_ORIGIN=http://localhost:5173