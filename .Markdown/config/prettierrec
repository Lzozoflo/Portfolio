{
  // ─── Ponctuation ──────────────────────────────────────────────────────────

  // Ajoute un point-virgule en fin de ligne
  // true → "const x = 1;"   false → "const x = 1"
  "semi": true,

  // Utilise des guillemets simples au lieu des doubles
  // true → 'hello'   false → "hello"
  "singleQuote": true,

  // Guillemets simples dans les fichiers JSX/TSX
  // true → <div className='foo'>   false → <div className="foo">
  "jsxSingleQuote": true,

  // Virgule trailing après le dernier élément
  // "all" → toujours (objets, tableaux, params de fonctions)
  // "es5" → seulement où c'est valide en ES5
  // "none" → jamais
  "trailingComma": "none",
  

  // ─── Indentation ─────────────────────────────────────────────────────────

  // Largeur d'une tabulation (en espaces)
  "tabWidth": 4,

  // Utilise des vraies tabulations au lieu d'espaces
  // true → \t   false → espaces
  "useTabs": false,

  // ─── Longueur de ligne ────────────────────────────────────────────────────

  // Longueur max d'une ligne avant retour à la ligne
  // Prettier essaie de respecter cette limite, pas une règle stricte
  "printWidth": 100,

  // ─── Espacement ───────────────────────────────────────────────────────────

  // Espaces à l'intérieur des accolades d'objets
  // true → { foo: bar }   false → {foo: bar}
  "bracketSpacing": true,

  // Accolade ouvrante d'un objet JSX sur la même ligne que le dernier prop
  // true → <Component
  //           foo="bar" {
  // false → <Component
  //            foo="bar"
  //          >

  "bracketSameLine": false,

  // ─── Fonctions fléchées ───────────────────────────────────────────────────

  // Parenthèses autour du paramètre unique d'une arrow function
  // "always" → (x) => x   "avoid" → x => x
  "arrowParens": "always",

  // ─── JSX / HTML ───────────────────────────────────────────────────────────

  // Un attribut JSX par ligne (quand il y en a plusieurs)
  // true → <Component
  //           foo="bar"
  //           baz="qux"
  //         />
  "singleAttributePerLine": false,

  // ─── Fin de fichier ───────────────────────────────────────────────────────

  // Caractère de fin de ligne
  // "lf" → \n (Linux/Mac)   "crlf" → \r\n (Windows)   "auto" → détecte
  "endOfLine": "lf",

  // Ajoute @prettier en haut des fichiers pour indiquer qu'ils sont formatés
  "requirePragma": false,
  // Insère automatiquement @prettier en haut des fichiers formatés
  "insertPragma": false,


  // Gestion du retour à la ligne dans le Markdown
  // "always" → retour à la ligne sur chaque phrase
  // "never" → jamais
  // "preserve" → respecte le fichier source
  "proseWrap": "always",
  // Indentation dans les fichiers imbriqués (ex: JSON dans Markdown)
  "embeddedLanguageFormatting": "auto"

}