{
  "extends": "../../tsconfig.front.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "FRONT/*" : ["./src/*"],
      "COMP/*"  : ["./src/Component/*"],
      "HOOKS/*" : ["./src/hooks/*"],
      "MEDIA/*" : ["./src/media"],
      "LIB/*"   : ["./src/lib/*"],
      "STYLE/*" : ["./src/style/*"],
      "@portfolio/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src", "main.tsx"]
}