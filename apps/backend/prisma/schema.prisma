generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String[] @default([])

  @@map("users")
}

model SpacyGameTool{
    id        String   @id @default(cuid())

    galaxie   Int     // one off the 10 galaxie in his univers
    system    Int     // one system in his galaxie
    planete   Int     // one planete in his system

    ressource Int     // the modificator off the planete
    energie   Int     // the modificator off the planete
    lancement Int     // the modificator off the planete

    owner     String?
    @@unique([galaxie, system, planete])
}